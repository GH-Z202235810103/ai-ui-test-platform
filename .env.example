# =============================================================================
# AI UI自动化测试平台 - 环境配置模板
# =============================================================================
# 复制此文件为 .env 并根据需要修改配置
# =============================================================================
# 注意：请将文件中的 "your_*_here" 替换为实际的值
# =============================================================================

# =============================================================================
# 1. 数据库配置
# =============================================================================
# 数据库类型：sqlite 或 mysql
DATABASE_TYPE=sqlite

# SQLite 数据库配置（默认）
DATABASE_URL=sqlite:///backend/data/ai_ui_test_platform.db

# MySQL 数据库配置（当 DATABASE_TYPE=mysql 时启用）
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_mysql_password_here
# DB_NAME=ai_ui_test_platform
# DATABASE_ECHO=False

# =============================================================================
# 2. API服务配置
# =============================================================================
# API服务主机地址
API_HOST=127.0.0.1

# API服务端口
API_PORT=8001

# API路由前缀
API_PREFIX=/api

# 跨域资源共享配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8081,http://localhost:8000,http://localhost:8001,http://127.0.0.1:8000,http://127.0.0.1:8001,*

# =============================================================================
# 3. Playwright浏览器自动化配置
# =============================================================================
# 是否使用无头模式运行浏览器
PLAYWRIGHT_HEADLESS=True

# 浏览器超时时间（毫秒）
PLAYWRIGHT_TIMEOUT=30000

# 操作延迟（毫秒），设置为0则不延迟
PLAYWRIGHT_SLOW_MO=0

# 浏览器视窗宽度
PLAYWRIGHT_VIEWPORT_WIDTH=1920

# 浏览器视窗高度
PLAYWRIGHT_VIEWPORT_HEIGHT=1080

# =============================================================================
# 4. OpenCV视觉定位配置
# =============================================================================
# 模板匹配阈值（0-1，越高越严格）
OPENCV_MATCH_THRESHOLD=0.8

# 模板缩放最小比例
OPENCV_SCALE_MIN=0.8

# 模板缩放最大比例
OPENCV_SCALE_MAX=1.2

# 缩放步数，影响匹配精度和速度
OPENCV_SCALE_STEPS=5

# =============================================================================
# 5. 文件目录配置
# =============================================================================
# 截图保存目录
SCREENSHOT_DIR=screenshots

# 视觉模板保存目录
VISUAL_TEMPLATE_DIR=backend/visual_templates

# 日志文件目录
LOG_DIR=logs

# 数据文件目录
DATA_DIR=backend/data

# 录制用例保存目录
RECORDING_DIR=recordings

# =============================================================================
# 6. 日志配置
# =============================================================================
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志格式
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# 日志文件名
LOG_FILE=app.log

# 是否输出日志到控制台
LOG_TO_CONSOLE=True

# =============================================================================
# 7. 缓存配置
# =============================================================================
# 缓存过期时间（秒）
CACHE_DURATION=60

# 缓存最大条目数
CACHE_MAX_SIZE=100

# =============================================================================
# 8. 测试运行配置
# =============================================================================
# 最大并发测试数
MAX_CONCURRENT_TESTS=3

# 单个测试超时时间（秒）
TEST_TIMEOUT=300

# 测试失败时是否保留浏览器实例
TEST_DEBUG_ON_FAILURE=False

# =============================================================================
# 9. 安全配置
# =============================================================================
# 密钥用于加密敏感数据
SECRET_KEY=your-secret-key-here-change-this-in-production

# 加密算法
ALGORITHM=HS256

# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 是否启用HTTPS
HTTPS_ENABLED=False

# =============================================================================
# 10. AI/LLM服务配置
# =============================================================================
# DeepSeek API密钥（用于测试用例AI生成）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API密钥（可选，备用）
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API密钥（可选，备用）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 默认使用的LLM模型
LLM_MODEL=deepseek-chat

# LLM API基础URL（默认为DeepSeek）
LLM_API_URL=https://api.deepseek.com/v1/chat/completions

# LLM请求超时时间（秒）
LLM_TIMEOUT=30

# LLM温度参数（0-1，控制随机性）
LLM_TEMPERATURE=0.7

# LLM最大令牌数
LLM_MAX_TOKENS=1000

# =============================================================================
# 11. 认证配置
# =============================================================================
# 是否启用认证
ENABLE_AUTH=False

# JWT密钥
JWT_SECRET_KEY=your-jwt-secret-key-here

# JWT过期时间（小时）
JWT_EXPIRE_HOURS=24

# 是否启用用户注册
ALLOW_REGISTRATION=False

# 管理员用户名（启用认证时必填）
ADMIN_USERNAME=admin

# 管理员密码（启用认证时必填）
ADMIN_PASSWORD=admin123

# =============================================================================
# 12. 监控配置
# =============================================================================
# 是否启用性能监控
ENABLE_MONITORING=True

# 监控数据收集间隔（秒）
MONITORING_INTERVAL=60

# 是否启用错误报告
ENABLE_ERROR_REPORTING=True

# 错误报告接收邮箱
ERROR_REPORT_EMAIL=admin@example.com

# =============================================================================
# 13. 开发调试配置
# =============================================================================
# 是否启用调试模式
DEBUG=False

# 是否显示开发者工具
DEV_TOOLS=False

# 是否启用详细的请求日志
LOG_REQUESTS=False

# 是否启用响应日志
LOG_RESPONSES=False

# =============================================================================
# 14. 第三方服务配置（可选）
# =============================================================================
# 邮件服务配置（用于发送通知）
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@example.com
# SMTP_PASSWORD=your_email_password
# SMTP_USE_TLS=True

# 消息队列配置（用于异步任务）
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=guest

# Redis缓存配置（可选，用于性能优化）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# =============================================================================
# 15. 备份配置
# =============================================================================
# 是否启用自动备份
ENABLE_AUTO_BACKUP=False

# 备份间隔（小时）
BACKUP_INTERVAL=24

# 备份保留天数
BACKUP_RETENTION_DAYS=7

# 备份目录
BACKUP_DIR=backups
